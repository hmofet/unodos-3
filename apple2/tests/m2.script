# UnoDOS/AppleII milestone-2 regression: Files + Notepad + speaker beeps.
# Run: ./build.sh test && python3 harness.py build/unodos_apple2_test.dsk shots \
#        --writeback build/unodos_apple2_test_written.dsk < tests/m2.script
# (the writeback image feeds tests/m2_persist.script - see README.md)
#
# Wait values calibrated via run_until_mainloop (instrs from keypress to back
# in mainloop's body, $4044-$4090): each `key` already runs KEY_INSTRS=30000
# steps, so the following `wait N` (N*TICK_INSTRS=5000 steps) covers the
# remainder with margin: open Files ~89.6K, open Notepad ~140.4K, each
# notepad_insert redraw ~60.4-61.2K, ctrl-s save (RWTS write, 2 sectors)
# ~667.8K.
wait 600
shot m2_desktop          # desktop: SysInfo/Clock windows open, Files icon present
key right                # sel_icon: Clock -> Files (~9.6K instrs, within KEY_INSTRS)
key return               # launch Files (disk-load: RWTS read into APP_BASE)
wait 200                 # head seek + multi-sector RWTS read + files_draw
shot m2_files            # HELLO.TXT/README.TXT listed with sizes, HELLO.TXT selected
key return               # open HELLO.TXT (87B) in Notepad (beep_click: app launch)
wait 24                  # notepad_load (fs_read) + beep_click + notepad_draw (~140.4K total)
shot m2_notepad          # title "Notepad: HELLO.TXT", content, status "Bytes:87"
key h
wait 7                   # notepad_insert + notepad_draw (~60.4K total)
key e
wait 7                   # (~60.6K total)
key l
wait 7                   # (~60.7K total)
key l
wait 7                   # (~61.0K total)
key o
wait 7                   # (~61.2K total)
shot m2_edited           # content now ends "...HELLO", status "Bytes:92"
key ctrl-s               # save: delete+append (HELLO.TXT becomes last) + beep_click
wait 129                 # fs_save (RWTS write) + beep_click + notepad_draw (~667.8K total)
assert beep>0            # speaker toggled (launch x2 + save)
shot m2_saved            # status line shows "Bytes:92  SAVED"
quit
