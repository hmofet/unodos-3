# UnoDOS/MacPlus games regression (M3). Capture after a key so the frame is
# a completed redraw (the continuous game loop can otherwise be caught mid-paint).
# Run: ./build.sh && python3 harness.py build/unodos_macplus.dsk shots < tests/games.script
wait 90
dblclick 52 96               # open Dostris (icon/proc 5, row 1)
wait 8
key n                        # new game: spawn a piece, gravity starts
wait 6
key left
wait 3
shot g_dostris_play          # board border + falling piece + score panel
key up                       # rotate
key right
wait 3
key space                    # hard drop -> lands, scores, next spawns
wait 6
shot g_dostris_drop
key esc                      # close Dostris
wait 3
dblclick 136 96              # open Pac-Man (icon/proc 6)
wait 8
key n                        # new game -> READY (auto-plays after ~60 ticks)
wait 80
key up                       # steer; dots score 10 each
wait 30
shot g_pacman_play           # maze + actors + SCORE > 0
key esc                      # close Pac-Man
wait 3
dblclick 212 96              # open OutLast (icon/proc 7)
wait 8
shot g_outlast_title         # black title screen: road bands + car + prompt
key n                        # drive: auto-accelerate, score accrues
wait 40
key left
wait 20
shot g_outlast_drive         # road perspective + dither grass + car + HUD
quit
