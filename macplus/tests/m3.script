# UnoDOS/MacPlus milestone-3 apps regression: Paint.
# Drag note: hold the button (wait) before/after moveto so the kernel's
# synchronous drag loop is entered while the button is down - tool-select
# repaints take ~30 ticks. A rare 1px clamp spike during long drags is the
# documented harness lazy-CCR artifact, not a kernel bug.
# Run: ./build.sh && python3 harness.py build/unodos_macplus.dsk shots < tests/m3.script
wait 90
dblclick 292 96              # open Paint (icon/proc 8)
wait 10
shot m3_paint_open           # tool grid, 4 ink swatches, white canvas
key 6                        # tool 6 = filled rect
wait 30
moveto 220 100
btn down
wait 10
moveto 260 130
wait 5
btn up
wait 10
shot m3_paint_frect          # black filled rect on the canvas
key s                        # save PAINT.UNO to the floppy
wait 40
key n                        # clear
wait 20
shot m3_paint_cleared
key l                        # load back from the floppy
wait 40
shot m3_paint_loaded         # the rect is back (byte-exact round-trip)
key esc                      # close Paint
wait 3
dblclick 372 96              # open Music (icon/proc 9)
wait 8
key space                    # play Canon in D (square voice)
wait 60
shot m3_music_playing        # staff + dithered notes, playing note black
key space                    # stop (buffer silenced)
wait 6
shot m3_music_stopped
key esc                      # close Music
wait 3
dblclick 52 144              # open Tracker (icon/proc 10, row 2)
wait 10
key d                        # load the shared demo song
wait 6
shot m3_tracker              # 12-row editor view, demo pattern, cursor row
key space                    # play (leftmost-voice on the square channel)
wait 30
key space                    # stop
wait 6
key s                        # save SONG.UNO to the floppy
wait 40
shot m3_tracker_saved
quit
