; ============================================================================
; UnoDOS/SNES sound (milestone 3): the 65816 side of the SPC700 audio driver.
;
; The driver blob + a square-wave BRR sample + the note-pitch table are
; generated by spc700.py and emitted into gen_data.inc. Here we:
;   - spc_upload   : the IPL ROM handshake on APU ports $2140-$2143 - load the
;                    blob into APU RAM and jump to it (HANDOFF SS6).
;   - spc_note_on  / spc_note_off : the mailbox protocol (token round-trip).
;   - sound_init   : upload, then a self-test (does the driver ack?), result
;                    in v_snd_ok so SysInfo / the rig can confirm audio is up.
;
; Every host<->APU wait is bounded by a timeout: a failed handshake (or no
; SPC) must never hang the kernel - it just leaves v_snd_ok = 0.
; ============================================================================

APUIO0 = $2140
APUIO1 = $2141
APUIO2 = $2142
APUIO3 = $2143

; spc_upload - IPL handshake; returns carry set on success, clear on timeout.
; X = image index (absolute-long indexed is X-only); Y = timeout counter.
; NOTE: every branch-target label below carries an explicit `.a8` - they are
; reached at runtime in 8-bit A, but `.smart` re-tracks width at the `rep #$20`
; in each timeout path, so without the assertion ca65 would assemble the next
; label's `lda #imm` as 16-bit (the HANDOFF width trap: a black-screen BRK).
.proc spc_upload
.a16
.i16
        sep #$20
.a8
        ; wait for the IPL ready signal ($AA in port0)
        ldy #$0000
@wready: lda APUIO0
        cmp #$AA
        beq @ready
        iny
        bne @wready
        rep #$20
        clc
        rts
@ready:
.a8
        ; begin block at SPC_IMAGE_ADDR
        lda #<SPC_IMAGE_ADDR
        sta APUIO2
        lda #>SPC_IMAGE_ADDR
        sta APUIO3
        lda #$01
        sta APUIO1              ; nonzero "kick"
        lda #$CC
        sta APUIO0
        ldy #$0000
@wcc:   lda APUIO0
        cmp #$CC
        beq @bytes
        iny
        bne @wcc
        rep #$20
        clc
        rts
@bytes:
.a8
        ldx #$0000
@byte:  lda f:spc_image,x
        sta APUIO1             ; data byte
        txa
        sta APUIO0            ; running index (low byte)
        ldy #$0000
@we:    cmp APUIO0
        beq @next
        iny
        bne @we
        rep #$20
        clc
        rts
@next:
.a8
        inx
        cpx #SPC_IMAGE_LEN
        bne @byte
        ; execute: entry to ports 2/3, 0 bytes (port1=0), advance port0 by +2
        lda #<SPC_ENTRY
        sta APUIO2
        lda #>SPC_ENTRY
        sta APUIO3
        stz APUIO1
        txa                    ; X low = LEN&$FF; +1 == last index +2
        ina
        sta APUIO0
        rep #$20
.a16
        sec
        rts
.endproc

; spc_send - A (8-bit) already holds port1; bump token, kick port0, await echo.
; Carry set on ack, clear on timeout. Enter with A 8-bit.
.proc spc_send
.a8
.i16
        sta APUIO1
        lda v_snd_tok
        inc a
        sta v_snd_tok
        sta APUIO0
        ldx #$0000
@w:     cmp APUIO0
        beq @ok
        inx
        bne @w
        clc
        rts
@ok:    sec
        rts
.endproc

; spc_note_on - A0 = voice (0-3), A1 = 14-bit DSP pitch
.proc spc_note_on
.a16
.i16
        sep #$20
.a8
        lda A1
        sta APUIO2             ; pitch low
        lda A1+1
        sta APUIO3             ; pitch high
        lda A0
        and #$0F
        ora #$10               ; opcode 1 (key-on) in the high nibble
        jsr spc_send
        rep #$20
.a16
        rts
.endproc

; spc_note_off - A0 = voice (0-3)
.proc spc_note_off
.a16
.i16
        sep #$20
.a8
        lda A0
        and #$0F               ; opcode 0 (key-off)
        jsr spc_send
        rep #$20
.a16
        rts
.endproc

; spc_note_idx - A = note index into note_pitch (0..PM_NOTE_COUNT-1) -> A1 = pitch
.proc spc_note_idx
.a16
.i16
        asl a
        tax
        lda note_pitch,x
        sta A1
        rts
.endproc

; sound_init - upload the driver and self-test it (key-off voice 0; the driver
; must echo the token). v_snd_ok = 1 on success.
.proc sound_init
.a16
.i16
        rep #$30                ; force 16-bit A/X/Y (caller width is unknown)
        stz v_snd_ok
        stz v_snd_tok
        jsr spc_upload
        bcc @done              ; upload timed out
        sep #$20
.a8
        lda #$00               ; opcode 0, voice 0 (harmless key-off)
        jsr spc_send
        rep #$20
.a16
        bcc @done
        lda #1
        sta v_snd_ok
@done:  rts
.endproc
