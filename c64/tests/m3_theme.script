wait 70
keys right right right   # sel_icon: SysInfo->Clock->Files->Theme (icon 3)
key return               # launch Theme (app3)
shot m3_theme
key down
key down                 # move cursor to Grape
key return               # apply
shot m3_theme_applied
key esc                  # back to launcher (now re-themed)
shot m3_theme_desktop
quit
