wait 70
shot m3_desktop          # 10-icon launcher grid
keys right right right right   # SysInfo->Clock->Files->Theme->Dostris (icon 4)
key return               # launch Dostris (app4)
shot m3_dostris          # board + falling piece + HUD
key left
key left                 # move piece left
wait 25                  # let gravity drop the piece
shot m3_dostris_play
quit
