# UnoDOS/C64 milestone 1 smoke test (AUTOTEST: launcher starts on SysInfo icon).
# Full-screen one-app-at-a-time model: the desktop is a pure icon-grid launcher;
# SysInfo and Clock are now disk-loaded apps (app0 / app1) like every other.
wait 60
shot m1_boot          # launcher desktop: menu bar, dithered bg, 10 icons
assert pal            # kernel auto-detected PAL from the raster counter
key right             # move icon selection (SysInfo -> Clock)
shot m1_select
key left              # back to SysInfo (icon 0)
key return            # launch SysInfo (app0) from disk, with a beep
assert beep>0
shot m1_launch        # full-screen SysInfo
key esc               # RUN/STOP returns to the launcher
shot m1_close         # back at the icon grid
key right             # select Clock (icon 1)
key return            # launch Clock (app1) from disk
shot m1_clock_boot    # full-screen Clock 12:00:0x
wait 90               # let the CIA Time-of-Day clock advance (tick redraws)
shot m1_clock         # Clock seconds advanced
quit
